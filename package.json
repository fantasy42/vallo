{
  "name": "vallo",
  "type": "module",
  "version": "0.1.0",
  "description": "Lightweight validation engine for dynamic strings and reserved identifiers.",
  "author": "Fantasy <fntsy42@pm.me>",
  "license": "MIT",
  "homepage": "https://github.com/fantasy42/vallo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fantasy42/vallo.git"
  },
  "bugs": {
    "url": "https://github.com/fantasy42/vallo/issues"
  },
  "keywords": [
    "validation",
    "typescript",
    "string-validator",
    "reserved-words",
    "route-validator",
    "username-validator",
    "identifier-check",
    "security",
    "zero-dependency",
    "tree-shakeable",
    "vallo"
  ],
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./extended": {
      "types": {
        "import": "./dist/extended.d.mts",
        "require": "./dist/extended.d.cts"
      },
      "import": "./dist/extended.mjs",
      "require": "./dist/extended.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "bench": "bun run benchmarks/validators.bench.ts",
    "lint:package": "publint",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build && bun run test && bun run lint:package",
    "release": "bumpp && npm publish"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "7.0.0-dev.20260309.1",
    "bumpp": "^10.4.1",
    "mitata": "^1.0.34",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3"
  }
}
